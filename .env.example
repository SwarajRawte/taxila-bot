# ============================================
# REQUIRED CREDENTIALS (Bot will not start without these)
# ============================================

# BITS Taxila Portal Credentials
# Format: your_email@wilp.bits-pilani.ac.in
TAXILA_USERNAME=your_email@wilp.bits-pilani.ac.in

# Your Taxila portal password
# ⚠️ NEVER commit this file to version control - it's in .gitignore
TAXILA_PASSWORD=your_taxila_password

# Telegram Bot Configuration
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID where notifications are sent
# Get it from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================
# OPTIONAL CONFIGURATION (defaults provided if not set)
# ============================================

# How often to check for new notifications (minutes)
CHECK_INTERVAL_MINUTES=10

# Hide browser window when scraping
HEADLESS_MODE=true

# Directory to store notification history
DATA_DIRECTORY=./data
